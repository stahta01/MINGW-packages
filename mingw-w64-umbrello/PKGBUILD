pkgname=umbrello
pkgver=17.04.3
pkgrel=1
pkgdesc='UML modeller'
arch=(i686 x86_64)
url='https://kde.org/applications/development/umbrello'
license=(GPL)
depends=(
  "${MINGW_PACKAGE_PREFIX}-hicolor-icon-theme"
  # ktexteditor
  # qt5-webkit
  "${MINGW_PACKAGE_PREFIX}-qtwebkit"
)
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-extra-cmake-modules"
  # kdoctools
  # python
)
conflicts=(kdesdk-umbrello)
replaces=(kdesdk-umbrello)
groups=(kde-applications kdesdk)
source=("https://download.kde.org/stable/applications/$pkgver/src/$pkgname-$pkgver.tar.xz"{,.sig})
noextract=("${pkgname}-${pkgver}.tar.xz")
sha256sums=('7a890d1d9da267c2980c4165a9558ec2ea3c638641462c82afce6556244926ec'
            'SKIP')
validpgpkeys=(CA262C6C83DE4D2FB28A332A3A6A4DB839EAA6D7  # Albert Astals Cid <aacid@kde.org>
              F23275E4BF10AFC1DF6914A6DBD2CE893E2D1C87) # Christoph Feck <cfeck@kde.org>

prepare() {
  cd $srcdir
  # work around an issue with symbolic links in the tarball.
  /usr/bin/bsdtar zxvf $srcdir/${pkgname}-${pkgver}.tar.xz || true

  mkdir -p build
}

build() {
  cd build
  MSYS2_ARG_CONV_EXCL="-DCMAKE_INSTALL_PREFIX=" \
  ${MINGW_PREFIX}/bin/cmake ../$pkgname-$pkgver \
    -G"MSYS Makefiles" \
    -DCMAKE_INSTALL_PREFIX=${MINGW_PREFIX} \
    -DCMAKE_BUILD_TYPE=Release \
    -DKDE_INSTALL_LIBDIR=lib \
    -DBUILD_TESTING=OFF \
    -DBUILD_UNITTESTS=OFF \
    -DBUILD_KF5=ON
  make
}

package() {
  cd build
  make DESTDIR="$pkgdir" install
}
